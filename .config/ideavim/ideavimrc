" set
set number relativenumber
set surround
set keep-english-in-normal
set idearefactormode=keep
set ideajoin
set NERDTree
set scrolloff=3

let mapleader = " "

" search
set incsearch
set hlsearch
set smartcase
set ignorecase
nmap <ESC><ESC> :noh<CR>

" easy system clipboard copy/paste
noremap <leader>y "*y
noremap <leader>Y "*Y
noremap <leader>p "*p
noremap <leader>P "*P

" tab
nmap <leader>h <Action>(PreviousTab)
nmap <leader>l <Action>(NextTab)
nmap <leader>q <Action>(CloseEditor)
nmap <leader>f <Action>(HideAllWindows)

" some action
map == <Action>(ReformatCode)
map -- <Action>(OptimizeImports)
map zc <Action>(CollapseRegion)
map zo <Action>(ExpandRegion)
map <leader>zc <Action>(CollapseAllRegions)
map <leader>zo <Action>(ExpandAllRegions)
map <leader>s <Action>(SelectInProjectView)
map <leader>/ <Action>(Find)


" run and debug, break point
map \r <Action>(RunClass)
map \R <Action>(Run)
map \d <Action>(DebugClass)
map \D <Action>(Debug)
map \b <Action>(ToggleLineBreakpoint)
map \q <Action>(Stop)


" back and forward
map <C-o> <Action>(Back)
map <C-i> <Action>(Forward)

" show java doc
map gh <Action>(QuickJavaDoc)

" rename
nmap <leader>rr <Action>(RenameElement)
